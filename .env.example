# ============================================
# MovieVerse — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================

# ---- TMDB API ----
# Get your free API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here

# ---- Authentication (NextAuth.js) ----
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Database ----
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/movieverse?schema=public"
# Redis connection
REDIS_URL="redis://localhost:6379"

# ---- Elasticsearch ----
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_API_KEY=

# ---- AI / LLM ----
# OpenAI for review summaries, search assistant
OPENAI_API_KEY=
# Or Google Gemini
GOOGLE_AI_API_KEY=

# ---- AWS S3 (Media Storage) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=movieverse-media
AWS_CLOUDFRONT_URL=

# ---- Stripe (Payments) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# ---- Analytics ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MovieVerse
NODE_ENV=development
